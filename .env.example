# ── Server ────────────────────────────────────────────────────
PORT=4000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/interior_db

# ── RunPod ────────────────────────────────────────────────────
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_COMFYUI_ENDPOINT_ID=your_comfyui_endpoint_id

# ── File storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
