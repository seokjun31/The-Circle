{
  "_comment": "The Circle — Material Apply Workflow (API format)",
  "_description": [
    "Pipeline: SDXL Base + IP-Adapter Advanced (texture style) + ControlNet Depth (perspective) + Inpainting",
    "SAM mask is pre-computed by the frontend (Transformers.js SAM) or backend SAM node,",
    "then passed in as base64 via ETN_LoadMaskBase64.",
    "",
    "Runtime injections (WorkflowManager.build_material_workflow):",
    "  Node 2   image           — room photo base64 (ETN_LoadImageBase64)",
    "  Node 3   mask            — SAM mask base64 (ETN_LoadMaskBase64, white=inpaint area)",
    "  Node 4   image           — material texture base64 (ETN_LoadImageBase64)",
    "  Node 5   ipadapter_file  — IP-Adapter model name",
    "  Node 7   weight          — IP-Adapter weight (0.4–0.7)",
    "  Node 10  text            — positive prompt",
    "  Node 11  text            — negative prompt",
    "  Node 12  strength        — ControlNet Depth strength",
    "  Node 14  seed/steps/cfg/denoise — KSampler params",
    "  Node 100 width/height    — SDXL-optimal dimensions from calc_sdxl_size()"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_label": "Load SDXL Base",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "25": {
    "class_type": "VAELoader",
    "_label": "Load SDXL VAE (improved colour fidelity)",
    "inputs": {
      "vae_name": "sdxl_vae.safetensors"
    }
  },
  "2": {
    "class_type": "ETN_LoadImageBase64",
    "_label": "Load Room Image",
    "inputs": {
      "image": ""
    }
  },
  "100": {
    "class_type": "ImageScale",
    "_label": "Scale to SDXL-optimal resolution",
    "inputs": {
      "image":          ["2", 0],
      "upscale_method": "lanczos",
      "width":          1024,
      "height":         1024,
      "crop":           "disabled"
    }
  },
  "3": {
    "class_type": "ETN_LoadMaskBase64",
    "_label": "Load SAM Mask (white = inpaint area)",
    "inputs": {
      "mask": ""
    }
  },
  "4": {
    "class_type": "ETN_LoadImageBase64",
    "_label": "Load Material Texture (IP-Adapter reference)",
    "inputs": {
      "image": ""
    }
  },
  "5": {
    "class_type": "IPAdapterModelLoader",
    "_label": "Load IP-Adapter SDXL Plus ViT-H",
    "inputs": {
      "ipadapter_file": "IP-Adapter-Plus_SDXL.safetensors"
    }
  },
  "6": {
    "class_type": "CLIPVisionLoader",
    "_label": "Load CLIP Vision Encoder (ViT-H-14)",
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "7": {
    "class_type": "IPAdapterAdvanced",
    "_label": "Apply IP-Adapter Advanced (material texture → style reference)",
    "inputs": {
      "model":          ["1", 0],
      "ipadapter":      ["5", 0],
      "image":          ["4", 0],
      "clip_vision":    ["6", 0],
      "weight":         0.55,
      "weight_type":    "linear",
      "combine_embeds": "concat",
      "start_at":       0.0,
      "end_at":         0.85,
      "embeds_scaling": "K+V"
    }
  },
  "8": {
    "class_type": "ControlNetLoader",
    "_label": "Load ControlNet Depth SDXL",
    "inputs": {
      "control_net_name": "controlnet-depth-sdxl-1.0.safetensors"
    }
  },
  "22": {
    "class_type": "DownloadAndLoadDepthAnythingV2Model",
    "_label": "Load Depth Anything V2 Model",
    "inputs": {
      "model":     "depth_anything_v2_vitl_fp32.safetensors",
      "precision": "auto"
    }
  },
  "9": {
    "class_type": "DepthAnythingV2",
    "_label": "Generate Depth Map (room perspective)",
    "inputs": {
      "da_model": ["22", 0],
      "images":   ["100", 0]
    }
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "_label": "Positive Prompt",
    "inputs": {
      "clip": ["1", 1],
      "text": "photorealistic interior, architectural photography, high-end material finish, seamless texture, perfect lighting, 8k resolution"
    }
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "_label": "Negative Prompt",
    "inputs": {
      "clip": ["1", 1],
      "text": "people, person, human, text, watermark, logo, blurry, low quality, artifacts, distorted, oversaturated, cartoon, anime, illustration, painting, unrealistic, dark, gloomy"
    }
  },
  "12": {
    "class_type": "ControlNetApplyAdvanced",
    "_label": "Apply ControlNet Depth (preserve room perspective & structure)",
    "inputs": {
      "positive":      ["10", 0],
      "negative":      ["11", 0],
      "control_net":   ["8",  0],
      "image":         ["9",  0],
      "strength":      0.65,
      "start_percent": 0.0,
      "end_percent":   0.8
    }
  },
  "13": {
    "class_type": "VAEEncodeForInpaint",
    "_label": "Encode for Inpainting (mask → latent noise mask)",
    "inputs": {
      "pixels":       ["100", 0],
      "vae":          ["25",  0],
      "mask":         ["3",   0],
      "grow_mask_by": 6
    }
  },
  "14": {
    "class_type": "KSampler",
    "_label": "KSampler (inpainting — material texture generation)",
    "inputs": {
      "model":        ["7",  0],
      "positive":     ["12", 0],
      "negative":     ["12", 1],
      "latent_image": ["13", 0],
      "seed":         42,
      "steps":        28,
      "cfg":          7.5,
      "sampler_name": "dpmpp_2m",
      "scheduler":    "karras",
      "denoise":      0.88
    }
  },
  "15": {
    "class_type": "VAEDecode",
    "_label": "Decode Latent → Image",
    "inputs": {
      "samples": ["14", 0],
      "vae":     ["25", 0]
    }
  },
  "16": {
    "class_type": "SaveImage",
    "_label": "Save Result",
    "inputs": {
      "images":          ["15", 0],
      "filename_prefix": "material_apply"
    }
  }
}
