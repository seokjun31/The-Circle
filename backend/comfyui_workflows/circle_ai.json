{
  "_comment": "The Circle — Circle AI Workflow (full-room style transform, API format)",
  "_description": [
    "Pipeline: SDXL Base + Korea-apartment LoRA + ControlNet Canny",
    "",
    "Runtime injections (WorkflowManager.build_circle_ai_workflow):",
    "  Node 4   image           — room photo base64",
    "  Node 20  strength_model  — LoRA strength (0 = disabled)",
    "  Node 2   text            — positive style prompt",
    "  Node 3   text            — negative prompt",
    "  Node 9   seed/steps/cfg/denoise",
    "  Node 100 width/height    — SDXL-optimal dimensions from calc_sdxl_size()"
  ],
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_label": "Load SDXL Base",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "20": {
    "class_type": "LoraLoader",
    "_label": "Korea Apartment Style LoRA",
    "inputs": {
      "model":          ["1", 0],
      "clip":           ["1", 1],
      "lora_name":      "korea-apartment-style_v1.safetensors",
      "strength_model": 0.7,
      "strength_clip":  0.7
    }
  },
  "4": {
    "class_type": "ETN_LoadImageBase64",
    "_label": "Load Room Image",
    "inputs": {
      "image": ""
    }
  },
  "100": {
    "class_type": "ImageScale",
    "_label": "Scale to SDXL-optimal resolution",
    "inputs": {
      "image":          ["4", 0],
      "upscale_method": "lanczos",
      "width":          1024,
      "height":         1024,
      "crop":           "disabled"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_label": "Positive Prompt",
    "inputs": {
      "clip": ["20", 1],
      "text": "photorealistic interior design, modern Korean apartment"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_label": "Negative Prompt",
    "inputs": {
      "clip": ["20", 1],
      "text": "people, person, human, text, watermark, logo, blurry, low quality, artifacts, distorted, oversaturated, cartoon, anime, illustration, painting, unrealistic, dark, gloomy"
    }
  },
  "5": {
    "class_type": "CannyEdgePreprocessor",
    "_label": "Canny Edge (structural lines)",
    "inputs": {
      "image":         ["100", 0],
      "low_threshold":  80,
      "high_threshold": 200,
      "resolution":     1024
    }
  },
  "6": {
    "class_type": "ControlNetLoader",
    "_label": "Load ControlNet Canny SDXL",
    "inputs": {
      "control_net_name": "controlnet-canny-sdxl-1.0.safetensors"
    }
  },
  "7": {
    "class_type": "ControlNetApplyAdvanced",
    "_label": "Apply ControlNet Canny",
    "inputs": {
      "positive":      ["2", 0],
      "negative":      ["3", 0],
      "control_net":   ["6", 0],
      "image":         ["5", 0],
      "strength":      0.55,
      "start_percent": 0.0,
      "end_percent":   0.7
    }
  },
  "8": {
    "class_type": "VAEEncode",
    "_label": "Encode for img2img",
    "inputs": {
      "pixels": ["100", 0],
      "vae":    ["1",   2]
    }
  },
  "9": {
    "class_type": "KSampler",
    "_label": "KSampler (style transform)",
    "inputs": {
      "model":        ["20", 0],
      "positive":     ["7",  0],
      "negative":     ["7",  1],
      "latent_image": ["8",  0],
      "seed":         42,
      "steps":        25,
      "cfg":          7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler":    "karras",
      "denoise":      0.65
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "_label": "Decode Latent",
    "inputs": {
      "samples": ["9", 0],
      "vae":     ["1", 2]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "_label": "Save Result",
    "inputs": {
      "images":          ["10", 0],
      "filename_prefix": "circle_ai"
    }
  }
}
