# =============================================================================
#  The Circle — 환경변수 설정 가이드
#
#  복사 후 실제 값으로 채우세요:
#    cp backend/.env.example backend/.env
#
#  ★ 로컬 개발 최소 설정 (아래 항목만 채우면 됩니다):
#    DATABASE_URL, SECRET_KEY
#    나머지는 기본값으로 로컬 테스트 가능
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# 로컬 개발: docker-compose.dev.yml 실행 후 아래 URL 사용
DATABASE_URL=postgresql+psycopg2://circle_user:circle_pass@localhost:5432/the_circle
# 프로덕션 예시 (Railway)
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/the_circle

# ── Redis (Celery 브로커) ──────────────────────────────────────────────────────
# 로컬 개발: docker-compose.dev.yml에 redis 추가 후 사용
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# openssl rand -hex 32 로 생성
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# USE_S3=false 이면 로컬 파일 저장소 사용 (개발용)
USE_S3=false
LOCAL_UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_BUCKET_NAME=the-circle-images
S3_BUCKET_NAME=the-circle-images

# ── ComfyUI Provider 선택 ─────────────────────────────────────────────────────
# "runpod" (기본값) → RunPod Serverless 사용
# "local"           → 로컬/다른 PC의 ComfyUI 직접 사용
COMFYUI_PROVIDER=runpod

# ── RunPod (AI 렌더링) ────────────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
# Scale to Zero MVP 설정 (0 = 항상 꺼짐, 비용 없음 / 1 = 항상 켜짐)
RUNPOD_MIN_WORKERS=0

# USE_MOCK_AI=true: RunPod 없이 보라색 placeholder 이미지로 AI 기능 테스트
USE_MOCK_AI=true

# ── 로컬 / 자체 호스팅 ComfyUI ───────────────────────────────────────────────
# COMFYUI_PROVIDER=local 일 때 사용
# 같은 머신:   http://localhost:8188
# LAN PC:      http://192.168.1.100:8188
# ngrok/터널:  https://xxxx.ngrok-free.app
COMFYUI_LOCAL_URL=http://localhost:8188
# ComfyUI에 인증이 설정된 경우 Bearer 토큰 입력 (보통 비워두면 됩니다)
COMFYUI_LOCAL_API_KEY=

# ── OAuth (소셜 로그인) ───────────────────────────────────────────────────────
# 소셜 로그인 없이 테스트할 경우 빈 값으로 둬도 됩니다
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── NextAuth (프론트엔드 연동) ────────────────────────────────────────────────
# openssl rand -hex 32 로 생성
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── App 설정 ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
HOST=0.0.0.0
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

DEFAULT_CREDIT_BALANCE=10
MAX_IMAGE_SIZE_MB=20
MAX_IMAGE_DIMENSION=2048
THUMBNAIL_SIZE=400

# ── 프론트엔드 환경변수 (client/.env에 추가) ──────────────────────────────────
# 아래는 client/ 디렉토리의 .env 파일에 넣어야 합니다
#
# REACT_APP_API_URL=http://localhost:8000
# REACT_APP_WS_URL=ws://localhost:8000
#
# Vercel 배포 시 Vercel 대시보드에서 설정:
# REACT_APP_API_URL=https://your-backend.railway.app
