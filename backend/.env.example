# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/the_circle

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Leave empty to use local file storage fallback
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=the-circle-uploads

# Set to false for local dev without AWS
USE_S3=false
LOCAL_UPLOAD_DIR=./uploads

# ── App ───────────────────────────────────────────────────────────────────────
DEFAULT_CREDIT_BALANCE=10
MAX_IMAGE_SIZE_MB=20
MAX_IMAGE_DIMENSION=2048
THUMBNAIL_SIZE=400

# ── RunPod (AI 기능) ──────────────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# 로컬 테스트 시 USE_MOCK_AI=true 로 설정하면 RunPod 없이 AI 기능 테스트 가능
# 실제 AI 이미지 대신 보라색 gradient placeholder 이미지가 반환됩니다
USE_MOCK_AI=true

# ── OAuth (소셜 로그인) ───────────────────────────────────────────────────────
# 소셜 로그인 없이 테스트할 경우 빈 값으로 둬도 됩니다
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
