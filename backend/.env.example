# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/the_circle

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Leave empty to use local file storage fallback
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=the-circle-uploads

# Set to false for local dev without AWS
USE_S3=false
LOCAL_UPLOAD_DIR=./uploads

# ── App ───────────────────────────────────────────────────────────────────────
DEFAULT_CREDIT_BALANCE=10
MAX_IMAGE_SIZE_MB=20
MAX_IMAGE_DIMENSION=2048
THUMBNAIL_SIZE=400

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
